{
  "rules": {
    // ✅ RÈGLES POUR LES UTILISATEURS (CLIENTS)
    "users": {
      "$uid": {
        // Lecture: seulement l'utilisateur lui-même
        ".read": "auth != null && auth.uid == $uid",
        
        // Écriture: seulement l'utilisateur lui-même
        ".write": "auth != null && auth.uid == $uid",
        
        // Validation des données
        ".validate": "newData.hasChildren(['name', 'email', 'phone'])",
        
        "name": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
        },
        "email": {
          ".validate": "newData.isString() && newData.val().matches(/^[A-Z0-9._%+-]+@[A-Z0-9.-]+\\.[A-Z]{2,}$/i)"
        },
        "phone": {
          ".validate": "newData.isString() && newData.val().length >= 8"
        },
        "blockStatus": {
          ".validate": "newData.val() == 'yes' || newData.val() == 'no'"
        },
        
        // Favoris de l'utilisateur
        "favorites": {
          "$favoriteId": {
            ".validate": "newData.hasChildren(['name', 'address', 'latitude', 'longitude'])"
          }
        },
        
        // Lieux récents
        "recentLocations": {
          "$locationId": {
            ".validate": "newData.hasChildren(['address', 'latitude', 'longitude'])"
          }
        }
      }
    },
    
    // ✅ RÈGLES POUR LES CHAUFFEURS
    "drivers": {
      "$uid": {
        // Lecture: tout le monde authentifié peut lire (pour voir les chauffeurs disponibles)
        ".read": "auth != null",
        
        // Écriture: seulement le chauffeur lui-même
        ".write": "auth != null && auth.uid == $uid",
        
        // Validation
        ".validate": "newData.hasChildren(['name', 'email', 'phone', 'car_details'])",
        
        "name": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "email": {
          ".validate": "newData.isString() && newData.val().matches(/^[A-Z0-9._%+-]+@[A-Z0-9.-]+\\.[A-Z]{2,}$/i)"
        },
        "phone": {
          ".validate": "newData.isString()"
        },
        "blockStatus": {
          ".validate": "newData.val() == 'yes' || newData.val() == 'no'"
        },
        "car_details": {
          ".validate": "newData.hasChildren(['carModel', 'carColor', 'carNumber'])"
        },
        "averageRating": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 5"
        },
        "totalRatings": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      }
    },
    
    // ✅ RÈGLES POUR LES CHAUFFEURS EN LIGNE (Geofire)
    "onlineDrivers": {
      "$driverId": {
        // Lecture: tout le monde authentifié
        ".read": "auth != null",
        
        // Écriture: seulement le chauffeur concerné
        ".write": "auth != null && auth.uid == $driverId",
        
        // Validation de la structure Geofire
        "l": {
          "0": {
            ".validate": "newData.isNumber() && newData.val() >= -90 && newData.val() <= 90"
          },
          "1": {
            ".validate": "newData.isNumber() && newData.val() >= -180 && newData.val() <= 180"
          }
        },
        "g": {
          ".validate": "newData.isString()"
        }
      }
    },
    
    // ✅ RÈGLES POUR LES DEMANDES DE COURSES
    "tripRequests": {
      "$tripId": {
        // Lecture: le client ET le chauffeur assigné peuvent lire
        ".read": "auth != null && (
          auth.uid == data.child('userID').val() || 
          auth.uid == data.child('driverID').val()
        )",
        
        // Écriture: 
        // - Le client peut créer la demande
        // - Le chauffeur peut accepter et modifier le statut
        ".write": "auth != null && (
          (auth.uid == newData.child('userID').val() && !data.exists()) ||
          (auth.uid == data.child('driverID').val() && data.exists()) ||
          (auth.uid == newData.child('driverID').val() && newData.exists())
        )",
        
        // Validation des champs obligatoires
        ".validate": "newData.hasChildren(['tripID', 'userID', 'status'])",
        
        "tripID": {
          ".validate": "newData.isString()"
        },
        "userID": {
          ".validate": "newData.isString()"
        },
        "userName": {
          ".validate": "newData.isString()"
        },
        "userPhone": {
          ".validate": "newData.isString()"
        },
        "driverID": {
          ".validate": "newData.isString()"
        },
        "status": {
          ".validate": "newData.val() == 'new' || newData.val() == 'accepted' || newData.val() == 'arrived' || newData.val() == 'ontrip' || newData.val() == 'ended' || newData.val() == 'completed' || newData.val() == 'cancelled'"
        },
        "pickUpAddress": {
          ".validate": "newData.isString()"
        },
        "dropOffAddress": {
          ".validate": "newData.isString()"
        },
        "distance": {
          ".validate": "newData.isString()"
        },
        "duration": {
          ".validate": "newData.isString()"
        },
        "fareAmount": {
          ".validate": "newData.isString() || newData.isNumber()"
        },
        "paymentMethod": {
          ".validate": "newData.val() == 'cash' || newData.val() == 'moncash' || newData.val() == 'natcash'"
        },
        "paymentStatus": {
          ".validate": "newData.val() == 'pending_driver_confirmation' || newData.val() == 'confirmed'"
        },
        "rating": {
          ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 5"
        }
      }
    },
    
    // ✅ RÈGLES POUR LES NOTIFICATIONS DE PAIEMENT
    "paymentNotifications": {
      "$driverId": {
        // Lecture: seulement le chauffeur concerné
        ".read": "auth != null && auth.uid == $driverId",
        
        // Écriture: le client peut créer, le chauffeur peut supprimer
        ".write": "auth != null && (
          (!data.exists() && auth.uid != $driverId) ||
          (data.exists() && auth.uid == $driverId)
        )",
        
        "tripID": {
          ".validate": "newData.isString()"
        },
        "fareAmount": {
          ".validate": "newData.isString() || newData.isNumber()"
        },
        "timestamp": {
          ".validate": "newData.isString()"
        }
      }
    },
    
    // ✅ RÈGLES POUR LES ADMINS (si vous en avez)
    "admins": {
      ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    }
  }
}
